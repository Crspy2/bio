---

<!-- Underlay -->
<div
  data-menu-underlay
  class="fixed z-10 rounded-xl bg-gradient-to-br from-blue-600 to-blue-500 shadow-lg shadow-blue-800/20"
  style="top: 16px; right: 16px; width: 80px; height: 80px;"
></div>

<!-- Hamburger Button -->
<button
  data-menu-button
  class="group fixed right-4 top-4 z-50 h-20 w-20 bg-white/0 transition-all hover:bg-white/20 rounded-xl"
>
  <span data-menu-bar="top" class="absolute block h-1 w-10 bg-white" style="top: 35%; left: 50%; transform: translate(-50%, -50%);"></span>
  <span data-menu-bar="middle" class="absolute block h-1 w-10 bg-white" style="left: 50%; top: 50%; transform: translate(-50%, -50%);"></span>
  <span data-menu-bar="bottom" class="absolute block h-1 w-5 bg-white" style="bottom: 35%; left: calc(50% + 10px); transform: translate(-50%, 50%);"></span>
</button>

<!-- Nav Overlay -->
<nav data-menu-overlay class="fixed right-4 top-4 z-40 h-[calc(100dvh_-_32px)] w-[calc(100%_-_32px)] overflow-hidden pointer-events-none opacity-0">
  <div class="flex flex-col items-start space-y-4 p-12 pl-4 md:pl-20">
    {LINKS.map((l, idx) => (
      <a
        data-menu-link
        data-index={idx}
        href={l.href}
        class="block text-5xl font-semibold text-blue-400 transition-colors hover:text-blue-50 md:text-7xl opacity-0"
        style="transform: translateY(-8px);"
      >
        {l.title}
      </a>
    ))}
  </div>

  <div class="absolute bottom-6 left-6 flex gap-4 md:flex-col">
    {SOCIAL_CTAS.map((l, idx) => (
      <a
        data-menu-social
        data-index={idx}
        target="_blank"
        href={l.href}
        class="text-xl 2xl:text-3xl text-white transition-colors hover:text-blue-300 opacity-0 [&>svg]:size-[1em]"
        style="transform: translateY(-8px);"
        set:html={l.icon}
      />
    ))}
  </div>

  <a
    href="mailto:crspy8687@gmail.com"
    data-menu-contact
    class="absolute bottom-2 right-2 flex items-center gap-2 rounded-full bg-blue-700 px-3 py-3 text-4xl uppercase text-blue-200 transition-colors hover:bg-white hover:text-blue-600 md:bottom-4 md:right-4 md:px-6 md:text-2xl opacity-0"
    style="transform: translateY(8px);"
  >
    <span class="hidden md:block">contact me</span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-[1em]"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
  </a>
</nav>

<script>
  import gsap from 'gsap'

  const button = document.querySelector('[data-menu-button]') as HTMLButtonElement
  const underlay = document.querySelector('[data-menu-underlay]') as HTMLDivElement
  const overlay = document.querySelector('[data-menu-overlay]') as HTMLElement
  const barTop = document.querySelector('[data-menu-bar="top"]') as HTMLSpanElement
  const barMiddle = document.querySelector('[data-menu-bar="middle"]') as HTMLSpanElement
  const barBottom = document.querySelector('[data-menu-bar="bottom"]') as HTMLSpanElement
  const links = document.querySelectorAll('[data-menu-link]')
  const socials = document.querySelectorAll('[data-menu-social]')
  const contact = document.querySelector('[data-menu-contact]') as HTMLElement

  let active = false
  let openTl: gsap.core.Timeline | null = null

  function openMenu() {
    // Kill any running timeline
    if (openTl) openTl.kill()

    button.classList.remove('rounded-xl')
    button.classList.add('rounded-bl-xl', 'rounded-tr-xl')

    // Show overlay immediately
    gsap.set(overlay, { opacity: 1, pointerEvents: 'auto' })

    openTl = gsap.timeline()

    // Underlay expansion
    openTl.to(underlay, {
      width: 'calc(100% - 32px)',
      height: 'calc(100dvh - 32px)',
      duration: 0.8,
      ease: 'elastic.out(0.5, 0.5)',
    }, 0)

    // Hamburger bars → X
    openTl.to(barTop, {
      keyframes: [
        { top: '50%', duration: 0.15 },
        { rotation: 45, duration: 0.15 },
      ],
    }, 0)
    openTl.to(barMiddle, {
      keyframes: [
        { duration: 0.15 },
        { rotation: -45, duration: 0.15 },
      ],
    }, 0)
    openTl.to(barBottom, {
      keyframes: [
        { bottom: '50%', left: '50%', duration: 0.15 },
        { rotation: 45, duration: 0.15 },
      ],
    }, 0)

    // Nav links stagger
    links.forEach((link, idx) => {
      openTl!.to(link, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: 'power2.inOut',
      }, 0.75 + idx * 0.125)
    })

    // Social CTAs stagger
    socials.forEach((social, idx) => {
      openTl!.to(social, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: 'power2.inOut',
      }, 1 + idx * 0.125)
    })

    // Contact button
    openTl.to(contact, {
      opacity: 1,
      y: 0,
      duration: 0.5,
      ease: 'power2.inOut',
    }, 1.125)
  }

  function closeMenu() {
    if (openTl) openTl.kill()

    button.classList.add('rounded-xl')
    button.classList.remove('rounded-bl-xl', 'rounded-tr-xl')

    const closeTl = gsap.timeline()

    // Fade out links, socials, contact
    closeTl.to(links, {
      opacity: 0,
      y: -8,
      duration: 0.3,
      ease: 'power2.inOut',
    }, 0)
    closeTl.to(socials, {
      opacity: 0,
      y: -8,
      duration: 0.3,
      ease: 'power2.inOut',
    }, 0)
    closeTl.to(contact, {
      opacity: 0,
      y: 8,
      duration: 0.3,
      ease: 'power2.inOut',
    }, 0)

    // Hamburger bars → lines
    closeTl.to(barTop, {
      keyframes: [
        { rotation: 0, duration: 0.15 },
        { top: '35%', duration: 0.15 },
      ],
    }, 0)
    closeTl.to(barMiddle, {
      keyframes: [
        { rotation: 0, duration: 0.15 },
      ],
    }, 0)
    closeTl.to(barBottom, {
      keyframes: [
        { rotation: 0, duration: 0.15 },
        { bottom: '35%', left: 'calc(50% + 10px)', duration: 0.15 },
      ],
    }, 0)

    // Underlay collapse (delayed)
    closeTl.to(underlay, {
      width: '80px',
      height: '80px',
      duration: 0.8,
      ease: 'elastic.out(0.5, 0.5)',
    }, 0.75)

    // Hide overlay after underlay collapses
    closeTl.set(overlay, { opacity: 0, pointerEvents: 'none' }, 1.55)
  }

  button.addEventListener('click', () => {
    active = !active
    if (active) {
      openMenu()
    } else {
      closeMenu()
    }
  })

  // Close menu when clicking a nav link
  links.forEach((link) => {
    link.addEventListener('click', () => {
      if (active) {
        active = false
        closeMenu()
      }
    })
  })
</script>
