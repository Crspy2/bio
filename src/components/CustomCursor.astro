<div
  id="custom-cursor"
  class="fixed top-0 left-0 w-3 h-3 bg-blue-400 rounded-full pointer-events-none z-50 opacity-0"
  style="box-shadow: 0 0 12px 2px rgba(96,165,250,0.4); transform: translate(-50%, -50%); mix-blend-mode: difference;"
></div>

<script>
  import gsap from "gsap";

  const isTouch = window.matchMedia("(pointer: coarse)").matches;
  const isSmallScreen = window.matchMedia("(max-width: 639px)").matches;
  if (!isTouch && !isSmallScreen) {
    const cursor = document.getElementById("custom-cursor")!;

    let state: "default" | "ibeam" | "morphed" = "default";
    let currentTarget: Element | null = null;
    let cursorVisible = false;

    const interactiveSelector =
      "a, button, [role='button'], input, textarea, select, label";
    const textSelector = "p, span, h1, h2, h3, h4, h5, h6, li, footer";

    function getState(target: Element) {
      const interactive = target.closest(interactiveSelector);
      if (interactive) return { type: "morphed" as const, el: interactive };

      const text = target.closest(textSelector) || target.closest("text");
      if (text && !target.closest("a, button")) {
        const display = getComputedStyle(text).display;
        if (!display.includes("flex") && !display.includes("grid")) {
          return { type: "ibeam" as const, el: text };
        }
      }

      return { type: "default" as const, el: null };
    }

    document.addEventListener("mousemove", (e) => {
      if (state !== "morphed") {
        gsap.to(cursor, {
          x: e.clientX,
          y: e.clientY,
          opacity: 1,
          duration: 0.15,
          ease: "power2.out",
        });
      }
      cursorVisible = true;

      const el = document.elementFromPoint(e.clientX, e.clientY);
      if (!el) return;
      const result = getState(el);

      if (result.type === "morphed" && result.el) {
        if (state !== "morphed" || currentTarget !== result.el) {
          morphToElement(result.el);
          state = "morphed";
          currentTarget = result.el;
        }
      } else if (result.type === "ibeam" && result.el) {
        if (state !== "ibeam") {
          morphToIBeam(result.el);
          state = "ibeam";
          currentTarget = null;
        }
      } else if (state !== "default") {
        morphToDefault();
        state = "default";
        currentTarget = null;
      }
    });

    document.documentElement.addEventListener("mouseout", (e) => {
      if (!e.relatedTarget && !(e as any).toElement) {
        gsap.to(cursor, { opacity: 0, duration: 0.15 });
        cursorVisible = false;
      }
    });

    document.documentElement.addEventListener("mouseover", (e) => {
      if (!cursorVisible) {
        gsap.to(cursor, { opacity: 1, duration: 0.15 });
        cursorVisible = true;
      }
    });

    document.addEventListener(
      "scroll",
      () => {
        if (state === "morphed" && currentTarget) {
          morphToElement(currentTarget);
        }
      },
      true,
    );

    document.addEventListener("mousedown", () => {
      gsap.to(cursor, { scale: 0.85, duration: 0.1, ease: "power2.in" });
    });

    document.addEventListener("mouseup", () => {
      gsap.to(cursor, {
        scale: 1,
        duration: 0.4,
        ease: "elastic.out(1, 0.3)",
      });
    });

    function morphToElement(el: Element) {
      const rect = el.getBoundingClientRect();
      const style = getComputedStyle(el);
      const br = parseInt(style.borderRadius) || 0;
      const fontSize = parseFloat(style.fontSize) || 16;

      const isTextLink =
        el.tagName === "A" && rect.height < fontSize * 3;

      const padX = isTextLink ? fontSize * 0.12 : 0;
      const padBottom = isTextLink ? fontSize * 0.1 : 0;

      cursor.style.mixBlendMode = "difference";
      cursor.style.backgroundColor = "white";
      gsap.to(cursor, {
        x: rect.left + rect.width / 2,
        y: rect.top + rect.height / 2 + padBottom / 2,
        width: rect.width + padX * 2,
        height: rect.height + padBottom,
        borderRadius: isTextLink ? `${br + padX}px` : style.borderRadius,
        opacity: 0.15,
        boxShadow: "none",
        duration: 0.3,
        ease: "power2.out",
        overwrite: true,
      });
    }

    function morphToIBeam(el: Element) {
      const fontSize = parseFloat(getComputedStyle(el).fontSize) || 16;
      cursor.style.mixBlendMode = "difference";
      cursor.style.backgroundColor = "";
      gsap.to(cursor, {
        width: 3,
        height: fontSize,
        borderRadius: "1px",
        boxShadow: "none",
        opacity: 1,
        duration: 0.2,
        ease: "power2.out",
        overwrite: true,
      });
    }

    function morphToDefault() {
      cursor.style.mixBlendMode = "difference";
      cursor.style.backgroundColor = "";
      gsap.to(cursor, {
        width: 12,
        height: 12,
        borderRadius: "9999px",
        opacity: 1,
        boxShadow: "0 0 12px 2px rgba(96,165,250,0.4)",
        duration: 0.3,
        ease: "power2.out",
        overwrite: true,
      });
    }
  }
</script>
