---
import LinkPreview from '@/components/ui/LinkPreview.tsx'
import GitHubGraph from '@/components/GitHubGraph.tsx'
import DiscordCard from '@/components/DiscordCard.astro'
import LinkButton from '@/components/ui/LinkButton.astro'
---

<div class="h-screen flex flex-col items-center justify-center gap-y-5 overflow-hidden">
  <div class="relative flex flex-col gap-y-5 bg-gray-900 py-4 sm:p-8 rounded-lg border border-slate-300/20">
    <div class="flex flex-col gap-y-4 justify-center items-center">
      <div data-gsap="hero" class="flex flex-col sm:flex-row gap-x-6">
        <img
          alt="Avatar"
          draggable="false"
          loading="lazy"
          decoding="async"
          class="bg-transparent rounded-full size-40 sm:size-30 mx-auto"
          src="https://cdn.discordapp.com/avatars/385568884511473664/d888e0052b5a6b7a8399cd81b4dc251f.webp?size=128"
        />
        <div class="flex flex-col text-center sm:text-start">
          <h3 class="font-moranga font-normal text-lg sm:text-xl lg:text-2xl text-blue-400">Computer Science Student</h3>
          <h1 class="font-moranga text-white font-black text-3xl sm:text-4xl md:text-5xl text-nowrap">Hi, I'm Crspy!</h1>
          <h4 class="text-gray-400 text-sm">Developer / Support</h4>
        </div>
      </div>
      <p data-gsap="bio" class="text-neutral-200 font-inter text-center sm:text-start text-sm md:text-base w-full sm:w-135">
        Founder and developer for{" "}
        <LinkPreview url="https://alterasms.io" client:visible>AlteraSMS</LinkPreview>. I am a developer interested in fullstack development, authentication, video game mods, and more...
      </p>
    </div>
    <div class="flex flex-col items-center justify-center gap-4 w-full sm:w-135">
      <GitHubGraph client:only="react" />
      <DiscordCard />
    </div>
  </div>
</div>

<script>
  import gsap from 'gsap'

  gsap.from('[data-gsap="hero"]', {
    scale: 0.5,
    opacity: 0,
    duration: 0.6,
    ease: 'power2.out',
  })

  gsap.from('[data-gsap="bio"]', {
    scale: 0.5,
    opacity: 0,
    duration: 0.6,
    delay: 0.1,
    ease: 'power2.out',
  })
</script>
